{
  "name": "memeboat-mcp",
  "version": "0.1.1",
  "mcpName": "io.github.memebo-at/memeboat-mcp",
  "description": "MCP server for Memeboat (memebo.at) — search 25,000+ meme templates and create memes from any AI assistant. Free, anonymous, no API key.",
  "type": "module",
  "bin": {
    "memeboat-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "meme",
    "memes",
    "meme-generator",
    "meme-templates",
    "memeboat",
    "ai",
    "claude",
    "images"
  ],
  "author": "Memeboat Team (https://memebo.at)",
  "license": "MIT",
  "homepage": "https://memebo.at",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/memebo-at/memeboat-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/memebo-at/memeboat-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
